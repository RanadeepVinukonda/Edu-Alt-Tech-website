rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "viranadeep@gmail.com";
    }
    
    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || request.auth.token.email == "viranadeep@gmail.com");
    }

    // Helper to check if a user is the designated author of a data object
    function isAuthor(data) {
      return isSignedIn() && (
        data.teacherId == request.auth.uid || 
        data.userId == request.auth.uid || 
        data.senderId == request.auth.uid ||
        isAdmin()
      );
    }

    // --- Global Admin Access ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // --- Courses ---
    match /courses/{courseId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // --- Course Enrollments ---
    match /enrollments/{enrollmentId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.userId); 
    }

    // --- Advanced Chat & Communication ---
    // Supports Course Broadcast Channels and Private Mentor-Student DMs
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        resource.data.type == 'community' || 
        request.auth.uid in resource.data.participants
      );
      allow create: if isSignedIn();
      
      match /messages/{msgId} {
        // Only members of the parent chat can read messages
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.type == 'community' ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow create: if isSignedIn();
        allow update, delete: if isAuthor(resource.data);
      }
    }
    
    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // --- Classroom Logic (Mentors can manage their own content) ---
    
    // Fixed: Collection name matches code 'course_modules'
    match /course_modules/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update, delete: if isAuthor(resource.data);
    }
    
    match /resources/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAuthor(resource.data);
    }

    // --- Mentor/Teacher Applications ---
    match /teacher_applications/{appId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isOwner(resource.data.userId) || 
        resource.data.status == 'approved'
      );
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Educational Sessions & Tracking ---
    match /subjects/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /chapters/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /classSessions/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAuthor(request.resource.data) || isAuthor(resource.data); 
    }
    
    match /attendance/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(resource.data.studentId);
    }

    // --- Patch Notes ---
    match /patch_notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
